NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# PostgreSQL is required in production. Leave empty only for local in-memory experiments.
DATABASE_URL=postgresql://kfc_tracks:change-me@localhost:5432/kfc_tracks
DATABASE_SSL=false
POSTGRES_PASSWORD=change-me-to-a-long-random-password

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# Telegram bot integration, used after the local dashboard/order flow is stable.
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_SECRET=replace-me
TELEGRAM_E2E_CHAT_ID=

STORE_TIME_ZONE=Asia/Ho_Chi_Minh
STORE_OPEN_HOUR=8
STORE_CLOSE_HOUR=22

# VNPay sandbox integration, used after COD flow is stable.
VNPAY_TMN_CODE=replace-me
VNPAY_HASH_SECRET=replace-me
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payments/vnpay/return
VNPAY_IPN_URL=http://localhost:3000/payments/vnpay/ipn
